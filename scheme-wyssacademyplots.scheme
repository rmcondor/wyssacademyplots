* white background --- Condor, R (2026)
* Based on Asjad Naqvi's schemes (2021) and cleanplot (Mize 2018)
*
*
*
sequence 1210
label "wyssacademyplots"   // auto generated
#include s2color

// positions and sizes
numstyle pcycle             15
clockdir legend_position     3
clockdir by_legend_position  6
numstyle legend_cols         1
numstyle legend_rows         0
gsize legend_key_xsize       5
yesno legend_col_first       no
yesno legend_row_first       yes
margin axis_title small
graphsize             5
graphsize x           6
graphsize y           4

// Sizes
gsize                 medsmall
gsize gap             tiny
gsize text            medsmall
gsize body            medsmall
gsize small_body      small
gsize axis_title      small
gsize matrix_label    large
gsize label           medsmall
gsize plabel          vsmall
