// Colors //
* White background for all plots
color background             white

* Textboxes
color box             gs15
color textbox         gs15
color mat_label_box   gs15
yesno textbox               no
linestyle textbox   none
linewidth textbox   vvthin
color heading    black
color subheading      black
color body     black
color small_body   black
color key_label    black
color axis_title   black
color tick_label   black
color plabel             black

* Wyss Academy brand colours (Comms Manual, March 2022)
* Primary: AAREBLAU | Secondary: KNOWLEDGE, ENGAGEMENT, SYNTHESIS, INCUBATOR
* Variants A/B/C from chromatic families for corporate publishing
color p1      "47 114 113"    // AAREBLAU (primary)
color p2      "65 134 174"    // KNOWLEDGE
color p3      "219 87 72"     // ENGAGEMENT
color p4      "242 186 82"    // SYNTHESIS
color p5      "119 156 104"   // INCUBATOR
color p6      "55 140 186"    // KNOWLEDGE A
color p7      "231 99 81"     // ENGAGEMENT A
color p8      "251 213 80"    // SYNTHESIS A
color p9      "193 191 102"   // INCUBATOR A
color p10     "45 118 158"    // KNOWLEDGE B
color p11     "200 86 70"     // ENGAGEMENT B
color p12     "223 179 72"    // SYNTHESIS B
color p13     "157 183 109"   // INCUBATOR B
color p14     "33 98 132"     // KNOWLEDGE C
color p15     "170 72 57"     // ENGAGEMENT C

